# Copy this file to .env and set values as needed.
# Do not commit .env (it is in .gitignore).

# URLHaus API (required for scripts/fetch_urlhaus.py). Get a free key at https://auth.abuse.ch/
URLHAUS_API_KEY=

# Optional: Path overrides
# DATA_DIR=data
# SAMPLES_DIR=sample data

# --- Bronze / silver / gold on S3 (medallion layout) ---
# Use s3a:// for Spark’s S3A filesystem (recommended for local PySpark). Plain s3:// in .env is OK too — pipeline_paths rewrites it to s3a://.
#
# AUTH_INPUT_URI=s3a://security-pipeline-lanl/bronze/lanl-auth-dataset-1.bz2
# DNS_INPUT_URI=s3a://security-pipeline-lanl/bronze/dns.txt.gz
# FLOWS_INPUT_URI=s3a://security-pipeline-lanl/bronze/flows.txt.gz
# PROC_INPUT_URI=s3a://security-pipeline-lanl/bronze/proc.txt.gz
#
# If unset, scripts use <DATA_DIR>/<default filename> on disk instead.

# --- Silver (Parquet): one prefix; *_to_parquet.py writes auth/, dns/, flows/, proc/ under it ---
# SILVER_PARQUET_URI=s3a://security-pipeline-lanl/silver
# ...or a local folder name (default when unset: Parquet/ under project root)
# PARQUET_OUTPUT_ROOT=Parquet

# --- Spark (optional) ---
# SPARK_MASTER=local[*]
# SPARK_DRIVER_MEMORY=8g
# SPARK_DRIVER_MAX_RESULT_SIZE=2g
# SPARK_LOCAL_DIR=C:\tmp\spark
# HADOOP_HOME=C:\hadoop
# AUTH_PARQUET_REPARTITION=2
# SPARK_SQL_SHUFFLE_PARTITIONS=2
# SPARK_SQL_ADAPTIVE_ENABLED=false

# Local PySpark + S3: JAR versions must match your Spark build’s Hadoop line
# SPARK_JARS_PACKAGES=org.apache.hadoop:hadoop-aws:3.3.4,com.amazonaws:aws-java-sdk-bundle:1.12.262

# --- URLHaus → S3 Parquet (scripts/urlhaus_to_parquet.py) ---
# S3_URLHAUS_BUCKET=security-pipeline-lanl
# S3_URLHAUS_KEY=silver/urlhaus/urlhaus.parquet
# AWS_REGION=us-east-1
